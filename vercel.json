{
  "outputDirectory": "dist/client",
  "functions": {
    "api/ssr.ts": {
      "includeFiles": "dist/server/**"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/sitemap\\.xml$",
      "dest": "/api/ssr"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/ssr"
    }
  ]
}
